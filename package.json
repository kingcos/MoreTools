{
  "name": "dorabox-vue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/merge": "^6.7.4",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.35.2",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^11.0.0",
    "codemirror": "^6.0.1",
    "diff-match-patch": "^1.0.5",
    "element-plus": "^2.9.0",
    "qr-scanner": "^1.4.2",
    "qrcode.vue": "^3.6.0",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.0.0-beta.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.30.0",
    "happy-dom": "^15.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.1",
    "vitest": "^2.0.0",
    "vue-tsc": "^2.1.10"
  }
